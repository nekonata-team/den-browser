require "digest"
require "fileutils"

ROOT = File.expand_path("..", __dir__)
PROJECT = File.join(ROOT, "Den Browser", "Den Browser.xcodeproj")
SCHEME = "Den Browser"

default_platform(:mac)

platform :mac do
  desc "Build, sign, notarize, and package a release candidate"
  lane :release_candidate do |options|
    tag = options[:tag].to_s
    UI.user_error!("Pass tag=vX.Y.Z") unless tag.match?(/\Av\d+\.\d+\.\d+\z/)

    version = tag.delete_prefix("v")
    project_version = get_version_number(xcodeproj: PROJECT, target: SCHEME)
    UI.user_error!("MARKETING_VERSION is #{project_version}, expected #{version}") unless project_version == version

    %w[ASC_KEY_ID ASC_ISSUER_ID ASC_KEY_PATH].each do |name|
      UI.user_error!("Set #{name}") if ENV[name].to_s.empty?
    end
    key_path = File.expand_path(ENV.fetch("ASC_KEY_PATH"))
    UI.user_error!("ASC key not found: #{key_path}") unless File.file?(key_path)

    output = File.join(ROOT, ".release", tag)
    archive = File.join(output, "Den Browser.xcarchive")
    app = File.join(archive, "Products", "Applications", "Den Browser.app")
    zip = File.join(output, "Den-Browser-#{version}-macOS.zip")

    FileUtils.rm_rf(output)
    FileUtils.mkdir_p(output)

    sh("just", "check")
    # sh("just", "ui-test")
    match(type: "developer_id", readonly: true, platform: "macos", skip_provisioning_profiles: true)
    build_app(
      project: PROJECT,
      scheme: SCHEME,
      configuration: "Release",
      archive_path: archive,
      output_directory: output,
      export_method: "developer-id",
      skip_package_pkg: true,
      clean: true
    )
    UI.user_error!("Built app not found: #{app}") unless File.directory?(app)

    info_plist = File.join(app, "Contents", "Info.plist")
    built_version = sh(
      "/usr/libexec/PlistBuddy",
      "-c", "Print :CFBundleShortVersionString",
      info_plist,
      log: false
    ).strip
    UI.user_error!("Built app version is #{built_version}, expected #{version}") unless built_version == version

    sh("codesign", "--verify", "--deep", "--strict", "--verbose=2", app)

    sh("ditto", "-c", "-k", "--sequesterRsrc", "--keepParent", app, zip)
    sh(
      "xcrun", "notarytool", "submit", zip,
      "--key", key_path,
      "--key-id", ENV.fetch("ASC_KEY_ID"),
      "--issuer", ENV.fetch("ASC_ISSUER_ID"),
      "--wait"
    )
    sh("xcrun", "stapler", "staple", app)
    sh("xcrun", "stapler", "validate", app)
    sh("spctl", "--assess", "--type", "execute", "--verbose=2", app)
    FileUtils.rm_f(zip)
    sh("ditto", "-c", "-k", "--sequesterRsrc", "--keepParent", app, zip)

    sha256 = Digest::SHA256.file(zip).hexdigest

    UI.success("#{zip}\nSHA-256: #{sha256}")
  end

  desc "Bump version and auto-increment build number"
  lane :bump_version do |options|
    version = options[:version]
    UI.user_error!("Pass version=X.Y.Z") if version.to_s.empty?

    increment_version_number(
      version_number: version,
      xcodeproj: PROJECT
    )
    increment_build_number(
      xcodeproj: PROJECT
    )
  end
end
