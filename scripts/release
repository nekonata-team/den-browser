#!/bin/zsh
set -euo pipefail

tag="${1:-}"
[[ "$tag" =~ '^v[0-9]+\.[0-9]+\.[0-9]+$' ]] || {
  print -u2 'usage: just release vX.Y.Z'
  exit 1
}

root="${0:A:h:h}"
version="${tag#v}"
archive="Den-Browser-${version}-macOS.zip"
zip="$root/.release/$tag/$archive"
tap="$root/.release/$tag/homebrew-tap"

cd "$root"
[[ -f "$zip" ]] || { print -u2 "missing candidate: $zip"; exit 1; }
[[ -z "$(git status --porcelain)" ]] || { print -u2 'working tree is not clean'; exit 1; }
[[ "$(git branch --show-current)" == main ]] || { print -u2 'release from main'; exit 1; }
git fetch origin main --tags
[[ "$(git rev-parse HEAD)" == "$(git rev-parse origin/main)" ]] || {
  print -u2 'push main before releasing'
  exit 1
}
! git rev-parse --verify --quiet "refs/tags/$tag" >/dev/null || {
  print -u2 "tag already exists: $tag"
  exit 1
}
! gh release view "$tag" --repo nekonata-team/den-browser >/dev/null 2>&1 || {
  print -u2 "release already exists: $tag"
  exit 1
}

latest="$(gh release list --repo nekonata-team/den-browser --limit 1 --json tagName --jq '.[0].tagName // "none"')"
sha256="$(shasum -a 256 "$zip" | cut -d ' ' -f 1)"
print "Latest release: $latest"
print "New release:    $tag"
print "SHA-256:        $sha256"
read -q "reply?Publish and update Homebrew Tap? [y/N] "
print
[[ "$reply" == y ]] || exit 1

gh api --method PUT repos/nekonata-team/den-browser/immutable-releases >/dev/null
git tag -a "$tag" -m "Den Browser $version"
git push origin "$tag"
gh release create "$tag" "$zip" \
  --repo nekonata-team/den-browser \
  --verify-tag \
  --title "$tag" \
  --notes ""

rm -rf "$tap"
gh repo clone nekonata-team/homebrew-tap "$tap"
mkdir -p "$tap/Casks"
cat >"$tap/Casks/den-browser.rb" <<EOF
cask "den-browser" do
  version "$version"
  sha256 "$sha256"

  url "https://github.com/nekonata-team/den-browser/releases/download/$tag/$archive",
      verified: "github.com/nekonata-team/den-browser/"
  name "Den Browser"
  desc "Niri-inspired spatial browser for persistent web work"
  homepage "https://nekonata.dev/"

  depends_on macos: ">= :tahoe"

  app "Den Browser.app"

  zap trash: "~/Library/Containers/dev.nekonata.denbrowser"
end
EOF

brew style "$tap/Casks/den-browser.rb"
brew audit --cask --strict "$tap/Casks/den-browser.rb"
brew fetch --cask --force "$tap/Casks/den-browser.rb"
git -C "$tap" checkout -B main
git -C "$tap" add Casks/den-browser.rb
git -C "$tap" commit -m "chore: Den Browser $tagへ更新"
git -C "$tap" push origin main
